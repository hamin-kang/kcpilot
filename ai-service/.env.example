# ai-service 환경변수 예시. 이 파일을 .env로 복사해 값을 채운다.
#   cp ai-service/.env.example ai-service/.env

# --- Vertex AI (필수) ---
# 인증은 GCP ADC로 한다: 최초 1회 `gcloud auth application-default login`.
# 해당 계정에 대상 프로젝트의 Vertex AI User 권한 + Vertex AI API 활성화 + 결제 연결 필요.
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# --- pgvector 접속 (필수) ---
# docker-compose의 POSTGRES_USER/PASSWORD와 일치해야 한다.
DATABASE_URL=postgresql+psycopg://hamin:1234@localhost:5432/kcpilot

# --- 데이터 수집 파이프라인 (선택, fetch 스크립트용) ---
# 국가법령정보 OPEN API 기관코드(OC) = 로그인 이메일의 @ 앞부분. pipeline/fetch_laws.py가 사용.
LAW_API_OC=
# 제품안전정보센터(safetykorea) Open API 키. pipeline/fetch_recalls.py가 사용.
SAFETYKOREA_API_KEY=
