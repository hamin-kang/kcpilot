# VM에 .env.prod 파일로 복사해 값을 채운다
# cp .env.prod.example .env.prod

# --- Artifact Registry 이미지 경로 ---
# 형식: REGION-docker.pkg.dev/PROJECT_ID/REPO_NAME
REGISTRY=asia-northeast3-docker.pkg.dev/YOUR_PROJECT_ID/kcpilot

# 배포할 이미지 태그 (GitHub Actions에서 git SHA로 자동 주입)
IMAGE_TAG=latest

# --- PostgreSQL ---
POSTGRES_DB=kcpilot
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# --- Backend ---
ADMIN_NAME=admin
ADMIN_PASSWORD=your_admin_password

# --- AI Service (Vertex AI) ---
GCP_PROJECT=YOUR_PROJECT_ID
GCP_LOCATION=us-central1

# --- Frontend ---
# 외부에서 backend API에 접근하는 URL (VM 공인 IP 또는 도메인)
NEXT_PUBLIC_API_URL=http://your-vm-ip:8080
