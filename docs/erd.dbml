// ==========================================================================
// KCpilot ERD (dbdiagram.io DBML)
// ==========================================================================
// 마지막 업데이트: 2026-05-26
//
// 참조:
//   - 요구사항: docs/requirements.md
//   - API 명세: docs/api/openapi.yaml
//   - 와이어프레임: docs/wireframes.html
//
// 핵심 설계 결정 요약 (자세한 내용 docs/requirements.md, 메모리 참조):
//   - assessment_id: varchar(12) NanoID (64^12 = 4.7e21 조합)
//   - 사용자 탈퇴 정책: 익명화 (users.deleted_at + assessments.user_id ON DELETE SET NULL)
//   - 신뢰도(confidence): 인증별로 부여 (진단 단위 X). 충실성(LLM) 주축 + 검색(RAG) 게이트.
//   - 법령명 비정규화 유지 (legal_sources에 직접 저장)
// ==========================================================================

Project KCpilot {
  database_type: 'PostgreSQL'
  Note: '''
    KC 인증 사전진단 AI 서비스 (PostgreSQL 18 + pgvector 0.8.2)
    본 ERD는 비즈니스 관계형 데이터 모델만 정의한다.
    RAG용 임베딩 벡터 테이블(pgvector langchain_pg_embedding 등)은 ai-service가 별도 관리.
  '''
}

// ==========================================================================
// ENUMS
// ==========================================================================

Enum AssessmentStatus {
  PENDING    [note: '진단 요청 접수']
  PROCESSING [note: 'LangGraph 워크플로우 실행 중']
  COMPLETED  [note: '진단 완료']
  FAILED     [note: '진단 실패 (failure_reason 참조)']
}

Enum ConfidenceLevel {
  HIGH   [note: 'confidenceScore >= 0.85']
  MEDIUM [note: '0.65 <= confidenceScore < 0.85']
  LOW    [note: 'confidenceScore < 0.65']
}

Enum CertificationAxis {
  SAFETY [note: '안전인증 축 (산업통상부/KATS)']
  EMC    [note: '전자파 인증 축 (과기부/국립전파연구원)']
}

Enum CertificationType {
  SAFETY_CERTIFICATION  [note: '안전인증 (시험+공장심사+정기검사)']
  SAFETY_CONFIRMATION   [note: '안전확인 (제품시험만)']
  SUPPLIER_DECLARATION  [note: '공급자적합성확인']
  EMC_CONFORMITY        [note: '적합인증']
  EMC_REGISTRATION      [note: '적합등록']
  EMC_SELF_DECLARATION  [note: '자기적합확인']
  EMC_PROVISIONAL       [note: '잠정인증']
}

Enum ProductCategory {
  ELECTRICAL_APPLIANCE [note: '전기용품']
  HOUSEHOLD_PRODUCT    [note: '생활용품']
  CHILDREN_PRODUCT     [note: '어린이제품']
}

Enum ReasoningStepName {
  CATEGORY_CLASSIFICATION
  CERTIFICATION_IDENTIFICATION
  TEST_ITEM_EXTRACTION
  LAB_RECOMMENDATION
  RECALL_SEARCH
  SELF_CRITIQUE
}

Enum UserRole {
  USER
  ADMIN
}

Enum OcrStatus {
  PENDING
  DONE
  FAILED
  SKIPPED
}

// ==========================================================================
// USERS
// ==========================================================================

Table users {
  id              bigserial    [pk]
  email           varchar(255) [not null, unique]
  password_hash   varchar(255) [not null, note: 'BCrypt 해시']
  display_name    varchar(100)
  role            UserRole     [not null, default: 'USER']
  email_verified  boolean      [not null, default: false]
  created_at      timestamp    [not null, default: `now()`]
  updated_at      timestamp    [not null, default: `now()`]
  deleted_at      timestamp    [note: 'soft delete + 익명화 트리거 시점']

  Indexes {
    email [unique]
    deleted_at
  }

  Note: '''
    탈퇴 정책: 익명화 (anonymization).
    탈퇴 처리 시:
      1) users 행에서 개인정보 컬럼 (email, display_name, password_hash) 마스킹·삭제
      2) deleted_at 세팅
      3) 자식 테이블의 user_id FK는 SET NULL 처리 (assessments, spec_sheet_files)
    진단 데이터 자체는 user_id=NULL로 보존하여 통계·분석에 활용한다.
  '''
}

// ==========================================================================
// SPEC SHEET FILES (사양서 업로드)
// ==========================================================================

Table spec_sheet_files {
  id                   bigserial     [pk]
  uploaded_by_user_id  bigint        [ref: > users.id, note: 'ON DELETE SET NULL']
  original_filename    varchar(500)  [not null]
  storage_path         varchar(1000) [not null, note: '오브젝트 스토리지 경로 또는 로컬 경로']
  content_type         varchar(100)  [not null, note: '예: application/pdf']
  size_bytes           bigint        [not null]
  ocr_extracted_text   text          [note: 'pdfplumber + LLM 후처리 결과 (F-09)']
  ocr_status           OcrStatus     [not null, default: 'PENDING']
  ocr_error            text          [note: 'ocr_status = FAILED일 때 사유']
  created_at           timestamp     [not null, default: `now()`]

  Indexes {
    uploaded_by_user_id
    ocr_status
  }
}

// ==========================================================================
// CERTIFICATION TYPES (마스터)
// ==========================================================================

Table certification_types {
  type        CertificationType [pk]
  axis        CertificationAxis [not null]
  name_ko     varchar(100)      [not null, note: '예: 안전확인']
  description text
  authority   varchar(200)      [note: '소관 부처/기관']
  is_active   boolean           [not null, default: true]

  Note: '''
    enum 값을 PK로 사용하는 마스터 테이블.
    부가 정보(name_ko, description, authority)를 join으로 가져온다.
    name_ko 변경 시 과거 진단 표시에 영향 — 강한 immutability가 필요해지면 snapshot 컬럼 추가 검토.
  '''
}

// ==========================================================================
// TEST ITEMS (마스터)
// ==========================================================================

Table test_items {
  id          bigserial    [pk]
  item_code   varchar(50)  [not null, unique, note: '예: SAF-001']
  name        varchar(200) [not null]
  description text
  is_active   boolean      [not null, default: true]
  created_at  timestamp    [not null, default: `now()`]
}

// ==========================================================================
// TEST LABS (마스터)
// ==========================================================================

Table test_labs {
  id          bigserial    [pk]
  lab_code    varchar(20)  [not null, unique, note: '예: KTL, KTR, KTC']
  name        varchar(200) [not null]
  specialty   varchar(500) [note: '예: 종합 (안전+전자파)']
  contact_url varchar(500)
  is_active   boolean      [not null, default: true]
  created_at  timestamp    [not null, default: `now()`]
}

// ==========================================================================
// RECALL CASES (마스터)
// ==========================================================================

Table recall_cases {
  id                bigserial    [pk]
  recall_code       varchar(50)  [not null, unique, note: '예: R-2024-0301']
  product_name      varchar(500) [not null]
  recall_date       date
  reason            text
  authority         varchar(200) [note: '발표 기관']
  external_metadata jsonb        [note: 'safetykorea Open API 원본. 비즈니스 로직이 내부 필드 참조하면 정규 컬럼 승격.']
  created_at        timestamp    [not null, default: `now()`]
  updated_at        timestamp    [not null, default: `now()`]

  Indexes {
    recall_code [unique]
    recall_date
  }
}

// ==========================================================================
// ASSESSMENTS (진단)
// ==========================================================================

Table assessments {
  id                  varchar(12) [pk, unique]
  user_id             bigint      [ref: > users.id, note: 'ON DELETE SET NULL — 탈퇴 시 익명화 보존']
  spec_sheet_file_id  bigint      [ref: > spec_sheet_files.id, note: 'ON DELETE SET NULL']

  product_name        varchar(100)  [not null]
  product_purpose     varchar(500)  [not null]
  uses_electricity    boolean       [not null]
  for_children        boolean       [not null]
  specifications      varchar(2000)

  status              AssessmentStatus [not null, default: 'PENDING']
  failure_reason      text             [note: 'status=FAILED일 때만']
  ambiguity_note      text             [note: 'F-05 모호 케이스 사용자 안내문']
  data_reference_date date             [note: '진단 사용 데이터 기준일 (응답에 노출)']

  created_at   timestamp [not null, default: `now()`]
  completed_at timestamp

  Indexes {
    user_id
    status
    created_at
    (user_id, created_at)
  }

  Note: '''
    PK는 12-char NanoID (64^12 = 4.7e21 조합, 첫 해 충돌률 << 0.0001% @10k/day).
    충돌 발생 시 재시도 로직 필수 (희귀성으로 단순 try-again 구현 가능).

    Confidence 정책:
      - 진단 단위에는 confidence를 부여하지 않는다.
      - 각 ApplicableCertification에 confidence 라벨이 부여된다 (applicable_certifications 참조).
      - UI상 "전문가 상담 권장" 경고는 LOW 라벨 존재 여부로 동적 판단.
      - 자세한 산출 로직: requirements.md §4.2.1
  '''
}

// ==========================================================================
// APPLICABLE CERTIFICATIONS (M:N: 진단 ↔ 인증유형)
// ==========================================================================

Table applicable_certifications {
  id                  bigserial         [pk]
  assessment_id       varchar(12)       [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  certification_type  CertificationType [not null, ref: > certification_types.type]

  confidence          ConfidenceLevel   [not null, note: '인증별 신뢰도 라벨 (API 응답에 노출)']
  confidence_score    numeric(3,2)      [not null, note: '신뢰도 점수 ∈ [0.00, 1.00]. 충실성(llmScore) 주축·검색(ragScore) 게이트. DB 전용, 응답 미노출. 산출: requirements.md §4.2.1']
  rationale           text              [note: 'AI가 이 인증이 필요하다고 판단한 근거 요약 (Explainable AI)']

  created_at          timestamp         [not null, default: `now()`]

  Indexes {
    (assessment_id, certification_type) [unique]
    assessment_id
    confidence
  }

  Note: '''
    한 진단에 같은 certification_type 중복 출현 방지 (unique 제약).

    confidence 산출 로직 (requirements.md §4.2.1):
      - ragScore: 제품정보 ↔ 법령 임베딩 cosine similarity (관련성 게이트, 0.0~1.0)
      - llmScore: LangGraph self-critique 노드의 근거 충실성 평가 (신뢰도 주축, 0.0~1.0)
      결합: 인용없음→0 / ragScore<0.45→min(llmScore,0.64)[LOW강등] / else→llmScore
      (기존 MIN 폐기: 코사인=관련성·LLM=충실성으로 척도가 달라 대등 결합 부적합)
      임계값(0.85/0.65)·게이트(0.45)는 정답셋 보정 전 잠정값
  '''
}

// ==========================================================================
// ASSESSMENT CATEGORIES (M:N: 진단 ↔ 제품 카테고리)
// ==========================================================================

Table assessment_categories {
  id            bigserial       [pk]
  assessment_id varchar(12)     [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  category      ProductCategory [not null]

  Indexes {
    (assessment_id, category) [unique]
    assessment_id
  }
}

// ==========================================================================
// ASSESSMENT TEST ITEMS (M:N: 진단 ↔ 시험 항목)
// ==========================================================================

Table assessment_test_items {
  id            bigserial   [pk]
  assessment_id varchar(12) [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  test_item_id  bigint      [not null, ref: > test_items.id, note: 'ON DELETE RESTRICT']

  Indexes {
    (assessment_id, test_item_id) [unique]
    assessment_id
  }
}

// ==========================================================================
// ASSESSMENT TEST LABS (M:N: 진단 ↔ 시험기관)
// ==========================================================================

Table assessment_test_labs {
  id            bigserial   [pk]
  assessment_id varchar(12) [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  test_lab_id   bigint      [not null, ref: > test_labs.id, note: 'ON DELETE RESTRICT']
  rank          int         [note: '추천 순위 (UI 정렬용, 1부터)']

  Indexes {
    (assessment_id, test_lab_id) [unique]
    assessment_id
  }
}

// ==========================================================================
// ASSESSMENT RECALL CASES (M:N: 진단 ↔ 유사 리콜 사례)
// ==========================================================================

Table assessment_recall_cases {
  id                bigserial    [pk]
  assessment_id     varchar(12)  [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  recall_case_id    bigint       [not null, ref: > recall_cases.id, note: 'ON DELETE RESTRICT']
  similarity_score  numeric(3,2) [note: 'RAG 검색 유사도 0.00~1.00']

  Indexes {
    (assessment_id, recall_case_id) [unique]
    assessment_id
  }
}

// ==========================================================================
// LEGAL SOURCES (진단 결과 근거 법령 — F-07)
// ==========================================================================

Table legal_sources {
  id                bigserial    [pk]
  assessment_id     varchar(12)  [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  law_name          varchar(500) [not null, note: '법령명 정식 명칭 (마스터화 안 함 — 비정규화 유지)']
  article_reference varchar(500) [note: '예: 시행규칙 별표 3 제○호']
  citation_text     text         [note: 'AI가 참조한 법령 본문 인용']
  source_url        varchar(1000) [note: '국가법령정보센터 등 원문 URL (있을 때)']

  Indexes {
    assessment_id
  }

  Note: '''
    law_name을 마스터화하지 않고 직접 저장하는 비정규화 결정 (project_erd_decisions.md 참조).
    이유: 법령 조항이 매우 세분되어 마스터화 가치 낮음, MVP에 검색 기능 미포함 가능성.
    AI 프롬프트에 "법령명은 정식 명칭 사용" 지시 필수.
    추후 통계·검색 기능 추가 시 별도 laws 마스터 테이블로 마이그레이션 검토.
  '''
}

// ==========================================================================
// REASONING STEPS (단계별 추론 로그 — F-06 Explainable AI)
// ==========================================================================

Table reasoning_steps {
  id              bigserial         [pk]
  assessment_id   varchar(12)       [not null, ref: > assessments.id, note: 'ON DELETE CASCADE']
  step_order      int               [not null, note: '실행 순서 (1부터)']
  step_name       ReasoningStepName [not null]

  input_summary   text [note: '이 단계 입력 요약']
  output_summary  text [note: '이 단계 출력 요약']
  reasoning       text [note: 'AI의 사고 과정 / 자기비판 노드의 경우 1차 결론 검토 결과']
  duration_ms     int  [note: '단계 소요 시간 (ms)']

  created_at timestamp [not null, default: `now()`]

  Indexes {
    (assessment_id, step_order) [unique]
    assessment_id
  }
}
